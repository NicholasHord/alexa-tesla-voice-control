# Server
NODE_ENV=production
PORT=3000
HOST_PORT=18765
PUBLIC_BASE_URL=https://tesla.example.com
APP_ENV_FILE=/app/.env
# Enabled automatically by scripts/generate-tesla-virtual-key.sh after keys exist.
COMPOSE_PROFILES=

# Setup UI
# The installer generates SETUP_ADMIN_TOKEN locally. Disable setup after configuration.
SETUP_ENABLED=false
SETUP_ADMIN_TOKEN=

# Alexa
# Example: amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ALEXA_SKILL_ID=
# Set only for local fixture tests. Keep false in production.
DISABLE_ALEXA_SIGNATURE_VERIFICATION=false

# Tesla OAuth / Fleet API
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REFRESH_TOKEN=
TESLA_VIN=
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_AUTH_BASE_URL=https://fleet-auth.prd.vn.cloud.tesla.com
TESLA_FLEET_BASE_URL=https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_REGION=na
TESLA_OAUTH_REDIRECT_URI=https://tesla.example.com/oauth/callback
TESLA_OAUTH_SCOPES=openid offline_access vehicle_device_data vehicle_cmds
TESLA_PARTNER_SCOPES=openid vehicle_device_data vehicle_cmds

# Local token persistence. If writable, refreshed tokens are rotated here.
TESLA_TOKEN_FILE=/app/data/tesla-tokens.json

# Official Tesla vehicle-command HTTP proxy sidecar
# The proxy should be reachable only on the Docker network, not from the internet.
TESLA_COMMAND_PROXY_URL=https://tesla-command-proxy:4443
TESLA_COMMAND_PROXY_CA_CERT=/app/certs/proxy-cert.pem
TESLA_PUBLIC_KEY_FILE=/app/public/com.tesla.3p.public-key.pem

# Command behavior
# Optional. When set, unlock/frunk/trunk commands require this PIN in-session.
COMMAND_PIN=
STATUS_CACHE_TTL_SECONDS=45
COMMAND_WAKE_TIMEOUT_SECONDS=45
COOL_TARGET_CELSIUS=19
